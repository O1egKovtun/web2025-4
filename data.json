import requests
import json

# Конструювання URL
url = "https://bank.gov.ua/NBUStatService/v1/statdirectory/exchange?date=20250506&json"

# Запит до API
response = requests.get(url)
data = response.json()

# Збереження у файл data.json
with open("data.json", "w", encoding="utf-8") as f:
    json.dump(data, f, ensure_ascii=False, indent=4)

print("Дані збережено у файл data.json")
